OPENAI_API_KEY=sk-your-key-here
OPENAI_TEXT_MODEL=gpt-4.1
OPENAI_IMAGE_MODEL=gpt-image-1

# 可选：把分析/质检/图片生成切换到 Kimi
AI_PROVIDER=openai
IMAGE_PROVIDER=openai
KIMI_API_KEY=sk-your-kimi-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_TEXT_MODEL=kimi-k2.6
KIMI_IMAGE_MODEL=kimi-k2.6
KIMI_IMAGE_ENDPOINT=https://api.moonshot.cn/v1/images/generations

# 可选：切换到阿里云百炼 / DashScope
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ALIYUN_TEXT_MODEL=qwen-plus
ALIYUN_IMAGE_MODEL=wan2.7-image
ALIYUN_IMAGE_SIZE=1K

# 可选：切换到火山引擎方舟 / 豆包
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_TEXT_MODEL=doubao-seed-1-6-251015
VOLCENGINE_IMAGE_MODEL=doubao-seedream-3-0-t2i-250415
VOLCENGINE_IMAGE_SIZE=2048x2048

# Public deployment URL used to build image URLs for model vision input.
# On Railway, set this to your public app URL, e.g. https://your-app.up.railway.app
# If omitted, the server derives it from X-Forwarded-Proto and Host.
PUBLIC_BASE_URL=

# DeepSeek text/vision-compatible chat endpoint.
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TEXT_MODEL=deepseek-v4-pro
